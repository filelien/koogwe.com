# Configuration SMTP pour le serveur KOOGWE
# Copiez ce fichier en .env et remplissez avec vos identifiants

# Configuration SMTP
# Pour Outlook/Office 365:
SMTP_HOST=smtp-mail.outlook.com
SMTP_PORT=587
SMTP_SECURE=false

# Pour Gmail:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false

# Pour un serveur SMTP personnalisÃ©:
# SMTP_HOST=smtp.votre-domaine.com
# SMTP_PORT=465
# SMTP_SECURE=true

# Identifiants SMTP
SMTP_USER=koogwe@outlook.fr
SMTP_PASSWORD=votre_mot_de_passe

# Email de destination pour les messages de contact
CONTACT_EMAIL=koogwe@outlook.fr

# Email de destination pour les candidatures chauffeur
DRIVER_CONTACT_EMAIL=koogwe@outlook.fr

# URL du frontend (pour CORS)
FRONTEND_URL=http://localhost:5173

# Configuration proxy (utile en production derriere Nginx/Render/Heroku)
TRUST_PROXY=1

# Port du serveur (optionnel, par dÃ©faut 3001)
PORT=3001
